<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs exclusion filter.
  Add false-positive patterns here with justification.
  — Each exclusion must be reviewed at each major release.
-->
<FindBugsFilter
    xmlns="https://github.com/spotbugs/filter/3.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0
                        https://raw.githubusercontent.com/spotbugs/spotbugs/3.1.0/spotbugs/etc/findbugsfilter.xsd">

    <!-- Exclude test classes from security checks (not production code) -->
    <Match>
        <Class name="~.*Test.*"/>
        <Bug category="SECURITY"/>
    </Match>

    <!-- Exclude generated protobuf classes -->
    <Match>
        <Package name="~.*\.grpc\..*"/>
    </Match>

    <!--
      False positives on final classes: SpotBugs incorrectly reports fields as unused
      when the class is final and fields are accessed only via method calls (not direct
      field reads in the bytecode analysis path). Verified manually that all fields are used.
    -->
    <Match>
        <Class name="dev.vibeafrika.pcm.common.security.LocalAesPiiProtectionProvider"/>
        <Bug pattern="UUF_UNUSED_FIELD"/>
    </Match>
    <Match>
        <Class name="dev.vibeafrika.pcm.common.domain.TenantId"/>
        <Bug pattern="UUF_UNUSED_FIELD"/>
    </Match>

    <!--
      False positive: TenantId.equals uses Java 16+ pattern matching instanceof
      (if (!(o instanceof TenantId tenantId))). SpotBugs EQ_UNUSUAL fires because
      it does not recognise the binding variable pattern as a standard equals contract.
      The implementation is correct and symmetric.
    -->
    <Match>
        <Class name="dev.vibeafrika.pcm.common.domain.TenantId"/>
        <Bug pattern="EQ_UNUSUAL"/>
    </Match>

    <!--
      False positives on Avro-generated classes in pcm-kafka-events.
      All EI_EXPOSE_REP, EI_EXPOSE_REP2, and MS_EXPOSE_REP bugs in the
      dev.vibeafrika.pcm.events package are in code generated by the Avro
      Maven plugin from .avsc schemas. The generated getters/setters and
      static DECODER/MODEL$ fields are required by the Avro serialization
      contract and cannot be changed without regenerating the sources.
      These classes are not part of the hand-written codebase.
    -->
    <Match>
        <Package name="dev.vibeafrika.pcm.events"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.events"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.events"/>
        <Bug pattern="MS_EXPOSE_REP"/>
    </Match>

    <!--
      False positives in pcm-domain encryption value objects and builders.

      EI_EXPOSE_REP on getters: all mutable collections (Set, List, Map) are
      wrapped with Collections.unmodifiableSet/List or Map.copyOf/List.copyOf
      in the constructor before being stored. The returned references are
      already immutable; SpotBugs does not track the unmodifiable wrapper.

      EI_EXPOSE_REP on Throwable getters (AuditError, BackupError, etc.):
      exposing a cause Throwable via getCause() is the standard Java exception
      pattern and does not constitute a security risk in this domain context.

      EI_EXPOSE_REP2 on Builder setters: all Builder classes copy the mutable
      collection into an immutable structure inside the private constructor
      (Map.copyOf, List.copyOf, Collections.unmodifiableSet). The builder
      setter stores a reference only temporarily; the final object is always
      immutable. This is the standard Builder pattern.
    -->
    <Match>
        <Package name="dev.vibeafrika.pcm.domain.encryption"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.domain.encryption"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.domain.encryption.config"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.domain.encryption.config"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!--
      False positives in use case classes (preference, profile, consent, segment).
      SpotBugs EI_EXPOSE_REP2 fires when a constructor stores an interface reference
      (PreferenceRepository, EventPublisher, etc.) injected as a dependency.
      Storing an interface via constructor injection is the standard DI pattern;
      it does not expose mutable internal state.
    -->
    <Match>
        <Package name="dev.vibeafrika.pcm.preference.application.usecase"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.profile.application.usecase"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.consent.application.usecase"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.segment.application.usecase"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!--
      False positives in JPA infrastructure layers (persistence entities and adapters).

      EI_EXPOSE_REP / EI_EXPOSE_REP2 on JPA entity getters/setters: Hibernate requires
      mutable getters and setters on @Entity classes to perform dirty checking and
      lazy loading. Defensive copies would break the JPA lifecycle. These are
      infrastructure-layer classes, not domain value objects.

      EI_EXPOSE_REP2 on repository adapter constructors: storing EntityManager or
      Spring Data repository interfaces via constructor injection is the standard
      Spring/JPA pattern and does not expose mutable internal state.
    -->
    <Match>
        <Package name="dev.vibeafrika.pcm.preference.infrastructure.persistence.entity"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.preference.infrastructure.persistence.entity"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.preference.infrastructure.persistence.repository"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.profile.infrastructure.persistence.entity"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.profile.infrastructure.persistence.entity"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.profile.infrastructure.persistence.repository"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.profile.infrastructure.external"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.consent.infrastructure.persistence.entity"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.consent.infrastructure.persistence.entity"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.consent.infrastructure.persistence.repository"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.segment.infrastructure.persistence.entity"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.segment.infrastructure.persistence.entity"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.segment.infrastructure.persistence.repository"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.segment.infrastructure.external"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!--
      False positives in pcm-infrastructure-spring encryption infrastructure.

      CT_CONSTRUCTOR_THROW: Infrastructure classes (KMSCircuitBreaker, DEKCache,
      AuditLogStore, BlindIndexService, KMS clients, NetworkSecurityConfiguration)
      validate constructor arguments and throw on invalid input. These classes are
      Spring-managed singletons, not subclassed, so finalizer attacks are not possible.

      PATH_TRAVERSAL_IN: Keystore/truststore paths in KMS clients (AwsKmsClient,
      AzureKeyVaultClient, GcpCloudKmsClient) and MtlsConfiguration come from
      application configuration (application.yml / environment variables), not from
      user-controlled HTTP input. These are admin-controlled paths.

      DMI_RANDOM_USED_ONLY_ONCE: SecureRandom instances in EntropySourceValidator
      are created for one-time entropy validation tests, not for key generation.
      Creating a new SecureRandom per test is intentional to avoid state sharing.
      The EncryptionAutoConfiguration.auditLogger() creates a SecureRandom to
      generate a one-time signing key — this is the correct pattern.

      URF_UNREAD_FIELD: KeyManager.KEKMetadata fields (keyId, context, environment,
      createdAt, rotatedAt, status) are populated for future use and audit logging.
      SpotBugs does not detect usage via reflection or serialization.

      ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD: EncryptionEntityListener.setAdapter()
      writes to a static field intentionally — this is the standard JPA entity
      listener pattern where Spring injects the adapter via a static setter so that
      JPA-instantiated listener instances can access the Spring-managed bean.

      REC_CATCH_EXCEPTION: EncryptionService.performEncryption() catches Exception
      to handle all JCA/JCE exceptions uniformly. This is intentional in crypto code.

      IA_AMBIGUOUS_INVOCATION: DEKCache anonymous LinkedHashMap subclass calls
      size() which is unambiguous in context — SpotBugs false positive on anonymous
      inner class method resolution.

      PREDICTABLE_RANDOM: AlgorithmMigrationService uses ThreadLocalRandom for
      gradual rollout percentage sampling (non-security use). This is not used for
      key generation or cryptographic operations.

      NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE: VaultKmsClient null checks are
      handled by the surrounding try/catch and Result error handling. SpotBugs
      cannot track the null-safety guarantees of the Vault SDK response objects.
    -->
    <Match>
        <Package name="dev.vibeafrika.pcm.infrastructure.encryption"/>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.infrastructure.encryption.kms"/>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.infrastructure.spring.encryption.network"/>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.infrastructure.encryption.kms"/>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.infrastructure.spring.encryption.network"/>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.infrastructure.encryption"/>
        <Bug pattern="DMI_RANDOM_USED_ONLY_ONCE"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.infrastructure.spring.config"/>
        <Bug pattern="DMI_RANDOM_USED_ONLY_ONCE"/>
    </Match>
    <Match>
        <Class name="dev.vibeafrika.pcm.infrastructure.encryption.KeyManager$KEKMetadata"/>
        <Bug pattern="URF_UNREAD_FIELD"/>
    </Match>
    <Match>
        <Class name="dev.vibeafrika.pcm.infrastructure.encryption.adapter.EncryptionEntityListener"/>
        <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD"/>
    </Match>
    <Match>
        <Class name="dev.vibeafrika.pcm.infrastructure.encryption.EncryptionService"/>
        <Bug pattern="REC_CATCH_EXCEPTION"/>
    </Match>
    <Match>
        <Class name="dev.vibeafrika.pcm.infrastructure.encryption.DEKCache$1"/>
        <Bug pattern="IA_AMBIGUOUS_INVOCATION_OF_INHERITED_OR_OUTER_METHOD"/>
    </Match>
    <Match>
        <Class name="dev.vibeafrika.pcm.infrastructure.encryption.AlgorithmMigrationService"/>
        <Bug pattern="PREDICTABLE_RANDOM"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.infrastructure.encryption.kms"/>
        <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
    </Match>
    <!-- EI_EXPOSE_REP in infrastructure spring layer (Spring config beans, adapters) -->
    <Match>
        <Package name="dev.vibeafrika.pcm.infrastructure.encryption"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.infrastructure.encryption"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.infrastructure.encryption.kms"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.infrastructure.encryption.kms"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.infrastructure.spring.config"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.infrastructure.spring.config"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.infrastructure.spring.encryption.network"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Package name="dev.vibeafrika.pcm.infrastructure.spring.encryption.network"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

</FindBugsFilter>
