# ─────────────────────────────────────────────────────────────────────────────
# PCM — Environment Variables Template
#
# QUICK START:
#   cp .env.example .env
#   docker compose up --build -d
#
# The values below work out of the box for local development.
# Change passwords before exposing this to any network.
# NEVER commit .env to version control (.gitignore already excludes it).
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=pcm
POSTGRES_PASSWORD=pcm-dev-password
POSTGRES_DB=pcm

# ── Keycloak Admin ────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin-dev-password

# ── Vault ─────────────────────────────────────────────────────────────────────
# Dev mode root token — Vault Transit is bootstrapped automatically on first start.
# Change this to a strong random value before exposing Vault to any network.
VAULT_DEV_ROOT_TOKEN_ID=pcm-dev-vault-token

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin-dev-password

# ── pgAdmin (only used with --profile tools) ──────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@pcm.dev
PGADMIN_DEFAULT_PASSWORD=admin-dev-password

# ── PCM Application ───────────────────────────────────────────────────────────
ENCRYPTION_ENVIRONMENT=DEV

# Blind index salt — used to make searchable encrypted indexes unique per deployment.
# The default value is safe for local dev. Change it before going to staging/prod.
BLIND_INDEX_GLOBAL_SALT=pcm-dev-blind-index-salt-change-before-staging

# KMS provider — VAULT uses the Vault Transit engine (bootstrapped automatically).
# Options: VAULT | AWS_KMS | AZURE_KEY_VAULT | GCP_KMS | LOCAL (unit tests only)
KMS_PROVIDER=VAULT

KMS_MTLS_ENABLED=false
NETWORK_MTLS_ENABLED=false
NETWORK_PRIVATE_SUBNET_ONLY=false
AUDIT_LOG_LEVEL=HIGH
